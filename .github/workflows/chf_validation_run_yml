name: Consequence Horizon Formalism Validation

on:
  workflow_dispatch:
    inputs:
      run_id:
        description: CHF validation run ID
        required: true
        default: CHF-VAL-005
        type: string

jobs:
  chf_validation:
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install pyyaml

      - name: Run CHF deterministic validator
        env:
          RUN_ID: ${{ github.event.inputs.run_id }}
        run: |
          python math_solver/validation/chf_deterministic_validator.py \
            --spec-dir math_solver/validation \
            --out-json math_solver/validation/brain_reports/chf_validation_report_${RUN_ID}.json \
            --out-md math_solver/validation/brain_reports/chf_validation_summary_${RUN_ID}.md

      - name: Write workflow summary
        if: always()
        env:
          RUN_ID: ${{ github.event.inputs.run_id }}
        run: |
          echo "# Consequence Horizon Formalism Validation" >> "$GITHUB_STEP_SUMMARY"
          echo "" >> "$GITHUB_STEP_SUMMARY"

          SUMMARY="math_solver/validation/brain_reports/chf_validation_summary_${RUN_ID}.md"
          if [ -f "$SUMMARY" ]; then
            cat "$SUMMARY" >> "$GITHUB_STEP_SUMMARY"
          else
            echo "CHF validation summary was not generated." >> "$GITHUB_STEP_SUMMARY"
          fi

      - name: Upload CHF validation reports
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: chf-validation-results
          path: math_solver/validation/brain_reports/
